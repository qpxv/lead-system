generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id         String   @id @default(cuid())
  name       String
  profileUrl String
  createdAt  DateTime @default(now())
  hasReplied Boolean  @default(false)
  notes      String   @default("")
  status     String   @default("active") // "active" | "conversation"

  @@index([status])
  @@index([createdAt])
}
